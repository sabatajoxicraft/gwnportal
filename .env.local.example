# ============================================================================
# GWN Portal – Local Secrets (GITIGNORED – never commit this file)
# ============================================================================
# Override any value from .env.development or .env.production here.
# This file is loaded for ALL environments on this machine.
# ============================================================================

# Database credentials
# DB_PASS=your_local_db_password

# GWN Cloud API credentials
# GWN_APP_ID=
# GWN_SECRET_KEY=
# GWN_NETWORK_ID=

# Twilio credentials
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_WHATSAPP_NO=
# TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_WA_VOUCHER_TEMPLATE_SID=
# TWILIO_SMS_VOUCHER_TEMPLATE_SID=
# TWILIO_SMS_LOGIN_TEMPLATE_SID=
# TWILIO_SMS_INVITATION_TEMPLATE_SID=
# TWILIO_WA_INVITATION_TEMPLATE_SID=
# TWILIO_WA_FREEFORM_TEMPLATE_SID=

# Google Maps
# GOOGLE_MAPS_API_KEY=
