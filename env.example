# ============================================================================
# GWN WiFi System Environment Configuration Template
# ============================================================================
# Environment files are loaded in CRA-style priority order:
#
#   Development: .env.development.local → .env.local → .env.development → .env
#   Production:  .env.production.local  → .env.local → .env.production  → .env
#
# Files ending in .local are gitignored (put secrets there).
# .env.development and .env.production are committed (non-secret defaults).
#
# To set up your local machine:
#   1. Copy .env.local.example → .env.local
#   2. Fill in your secrets (API keys, passwords, etc.)
#
# On production (student.joxicraft.co.za):
#   Set APP_ENV=production in the server environment or .env.local
# ============================================================================

# ============================================================================
# Application Environment
# ============================================================================
# Valid values: development | production
APP_ENV=development
APP_DEBUG=1

# ============================================================================
# Session Security Configuration
# ============================================================================
# Session timeout in seconds (default: 1800 = 30 minutes)
SESSION_TIMEOUT=1800

# Session ID regeneration interval in seconds (default: 3600 = 1 hour)
SESSION_REGENERATE_INTERVAL=3600

# Secure cookie flag (set to 1 in production with HTTPS)
SESSION_COOKIE_SECURE=0

# SameSite cookie attribute (Strict, Lax, or None)
SESSION_COOKIE_SAMESITE=Strict

# ============================================================================
# GWN API Configuration
# ============================================================================
# The base URL for your GWN Manager API
DEFAULT_URL=https://your-gwn-manager-url.com

# Your GWN application credentials
ID=your_app_id
Key=your_secret_key

# GWN access token (if you have a static one, otherwise leave empty)
Access_token=

# Maximum number of devices allowed per voucher
GWN_ALLOWED_DEVICES=2

# ============================================================================
# Twilio Configuration (for SMS and WhatsApp messaging)
# ============================================================================
# Your Twilio account credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio phone numbers
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NO=+1234567890

# Twilio messaging service and template IDs
TWILIO_MESSAGE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SMS_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: WhatsApp Content Template SID with a single variable {{1}} used for
# business-initiated/freeform-style sends outside the 24-hour session window.
TWILIO_WA_FREEFORM_TEMPLATE_SID=
# SMS invitation code template SID (Content API).
# Template variables: {{1}} first name, {{2}} invitation code, {{3}} register URL, {{4}} expiry date.
# Leave empty to fall back to a plain-text SMS.
TWILIO_SMS_INVITATION_TEMPLATE_SID=
# WhatsApp invitation code template SID (Content API).
# Template variables: {{1}} first name, {{2}} invitation code, {{3}} register URL, {{4}} expiry date.
# If not set, falls back to TWILIO_SMS_INVITATION_TEMPLATE_SID. If neither is set, send is blocked.
TWILIO_WA_INVITATION_TEMPLATE_SID=

# Message template (use {0} for name, {1} for month, {2} for voucher code)
TWILIO_MESSAGE_TEMPLATE=Hi {0}, your WiFi voucher for {1} is: {2}. Valid for the entire month!

# ============================================================================
# Microsoft OneDrive Configuration (for Excel file management)
# ============================================================================
# Azure AD application credentials
CLIENT_ID=your_azure_client_id
CLIENT_SECRET=your_azure_client_secret
TENANT_ID=your_azure_tenant_id

# OneDrive file details
FILE_ID=your_excel_file_id
FILE_NAME=student_records.xlsx
FOLDER_PATH=/path/to/your/folder

# Azure authority URL
AUTHORITY_URL=https://login.microsoftonline.com/your_tenant_id

# ============================================================================
# Google Maps Configuration (for Street View JS rendering)
# ============================================================================
GOOGLE_MAPS_API_KEY=

# ============================================================================
# SMTP Configuration (PHPMailer – primary outbound email transport)
# ============================================================================
# SMTP server hostname
SMTP_HOST=student.joxicraft.co.za

# Port: 465 = implicit TLS (SMTPS, recommended), 587 = STARTTLS
SMTP_PORT=465

# Authenticated SMTP credentials
SMTP_USER=donotreply@student.joxicraft.co.za
SMTP_PASSWORD=your_smtp_password_here

# Envelope From / Display From address
SMTP_FROM=donotreply@student.joxicraft.co.za

# Encryption: 'ssl' for port 465, 'tls' for port 587, '' for none
# If omitted, defaults to 'ssl' when port=465, 'tls' otherwise.
SMTP_ENCRYPTION=ssl

# Set to 0 only if connecting to an unauthenticated relay (not recommended)
SMTP_AUTH=1