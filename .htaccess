RewriteEngine On
# RewriteBase / is implied.
# Fix for LiteSpeed: Allow valid files/directories to be served directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Exclude setup_db.php from rewrite
RewriteCond %{REQUEST_URI} !^/setup_db.php$

# Main rewrite rule
RewriteRule ^(.*)$ public/$1 [L]
